AI_SEARCH_IMAGE=ai-search-gpt:dev
AI_SEARCH_MODELS_ROOT=/data/ai-search/models

# Development Elasticsearch endpoint
AI_SEARCH_ES_URL=http://<dev-elasticsearch-host>:9200
AI_SEARCH_ES_USERNAME=elastic
AI_SEARCH_ES_PASSWORD=<change-me>

# First deployment: ,indexing-web,search-vector-only
# Later web-only restart: ,search-vector-only
MODEL_EXTRA_PROFILES=,indexing-web,search-vector-only

AI_SEARCH_PORT_E5_SMALL_KO_V2=8091
AI_SEARCH_PORT_KURE_V1=8092
AI_SEARCH_PORT_BGE_M3=8093

JAVA_OPTS_E5_SMALL_KO_V2=-Xms512m -Xmx1536m
JAVA_OPTS_KURE_V1=-Xms512m -Xmx1536m
JAVA_OPTS_BGE_M3=-Xms768m -Xmx2048m
